{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agentic Desktop",
  "version": "0.1.0",
  "identifier": "com.agenticapp.desktop",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix frontend run dev",
    "beforeBuildCommand": "npm --prefix frontend run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Agentic Desktop",
        "width": 1000,
        "height": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["binaries/agent-backend"],
    "publisher": "Agentic App",
    "copyright": "Copyright © 2026 Agentic App",
    "category": "Productivity",
    "shortDescription": "Local desktop app for running tool-using AI agents.",
    "longDescription": "A Windows desktop app for creating and chatting with tool-using AI agents backed by OpenRouter. Runs a local Python sidecar bound to 127.0.0.1; conversations, agents, and keys stay on your machine.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "installer-hooks.nsh"
      }
    }
  }
}
